{
  "name": "@ncbijs/clinical-tables",
  "sourceRoot": "packages/clinical-tables/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/clinical-tables/tsconfig.build.json && node scripts/add-import-extensions.mjs packages/clinical-tables/dist"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run --config packages/clinical-tables/vitest.config.ts" }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": { "lintFilePatterns": ["{projectRoot}/**/*.ts"] }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit -p packages/clinical-tables/tsconfig.json" }
    }
  }
}
