{
  "name": "@ncbijs/xml",
  "version": "0.0.0",
  "description": "Zero-dependency regex-based XML reader for NCBI document formats",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/xml"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/xml#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbijs",
    "xml",
    "xml-reader",
    "xml-parser",
    "ncbi",
    "regex",
    "zero-dependency",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
