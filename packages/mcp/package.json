{
  "name": "@ncbijs/mcp",
  "version": "0.0.1",
  "description": "MCP server exposing NCBI biomedical literature tools for LLM agents",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/mcp#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbi",
    "mcp",
    "model-context-protocol",
    "pubmed",
    "pmc",
    "biomedical",
    "llm",
    "ai",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ncbijs-mcp": "./dist/index.js"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "prepublishOnly": "echo 'Use CI to publish' && exit 1",
  "sideEffects": false,
  "files": [
    "dist",
    "package.json",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@ncbijs/cite": "workspace:*",
    "@ncbijs/datasets": "workspace:*",
    "@ncbijs/id-converter": "workspace:*",
    "@ncbijs/pmc": "workspace:*",
    "@ncbijs/pubmed": "workspace:*",
    "@ncbijs/pubtator": "workspace:*",
    "@ncbijs/mesh": "workspace:*",
    "@ncbijs/blast": "workspace:*",
    "@ncbijs/snp": "workspace:*",
    "@ncbijs/clinvar": "workspace:*",
    "@ncbijs/pubchem": "workspace:*",
    "zod": "^3.24.0"
  }
}
