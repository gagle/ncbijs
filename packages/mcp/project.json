{
  "name": "@ncbijs/mcp",
  "sourceRoot": "packages/mcp/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p packages/mcp/tsconfig.build.json" },
      "outputs": ["{projectRoot}/dist"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": { "lintFilePatterns": ["{projectRoot}/**/*.ts"] }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit -p packages/mcp/tsconfig.json" }
    }
  }
}
