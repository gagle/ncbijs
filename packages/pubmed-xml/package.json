{
  "name": "@ncbijs/pubmed-xml",
  "version": "0.0.1",
  "description": "Spec-compliant parser for PubMed/MEDLINE XML format",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/pubmed-xml"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/pubmed-xml#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbi",
    "pubmed",
    "xml",
    "medline",
    "parser",
    "bioinformatics",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "prepublishOnly": "echo 'Use CI to publish' && exit 1",
  "dependencies": {
    "@ncbijs/xml": "workspace:*"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "package.json",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
