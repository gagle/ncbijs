{
  "name": "@ncbijs/store",
  "version": "0.0.0",
  "description": "Storage interfaces and DuckDB strategy for local NCBI data",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/store"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/store#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbijs",
    "ncbi",
    "store",
    "storage",
    "duckdb",
    "local",
    "pipeline",
    "bioinformatics",
    "typescript"
