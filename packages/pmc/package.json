{
  "name": "@ncbijs/pmc",
  "version": "0.0.0",
  "description": "PMC full-text article retrieval via E-utilities, OA Service, and OAI-PMH",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/pmc"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/pmc#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbijs",
    "ncbi",
    "pmc",
    "pubmed-central",
    "full-text",
    "article",
    "rag",
    "bioinformatics",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "dependencies": {
    "@ncbijs/eutils": "workspace:*",
    "@ncbijs/jats": "workspace:*",
    "@ncbijs/xml": "workspace:*"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prepublishOnly": "echo 'Use CI to publish' && exit 1"
  }
}
