{
  "name": "@ncbijs/clinvar",
  "version": "0.0.1",
  "description": "Typed client for NCBI ClinVar clinical variant data",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/clinvar"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/clinvar#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbijs",
    "ncbi",
    "clinvar",
    "variant",
    "clinical",
    "pathogenic",
    "disease",
    "genomics",
    "bioinformatics",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "prepublishOnly": "echo 'Use CI to publish' && exit 1",
  "dependencies": {
    "@ncbijs/eutils": "workspace:*",
    "@ncbijs/rate-limiter": "workspace:*"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ]
}
