{
  "name": "@ncbijs/icite",
  "version": "0.0.0",
  "description": "Typed client for the NIH iCite API — citation metrics, Relative Citation Ratio, and impact analysis",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/icite"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/icite#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbijs",
    "icite",
    "citation",
    "rcr",
    "relative-citation-ratio",
    "impact",
    "nih",
    "pubmed",
    "typescript"
  ],
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@ncbijs/rate-limiter": "workspace:*"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prepublishOnly": "echo 'Use CI to publish' && exit 1"
  }
}
