{
  "name": "@ncbijs/http-mcp",
  "sourceRoot": "packages/http-mcp/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/http-mcp/tsconfig.build.json && tsc-esm-imports packages/http-mcp/dist --external-deep --ignore '@ncbijs/*'"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config packages/http-mcp/vitest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": { "lintFilePatterns": ["{projectRoot}/**/*.ts"] }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit -p packages/http-mcp/tsconfig.json" }
    }
  }
}
