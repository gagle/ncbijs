{
  "name": "@ncbijs/nucleotide",
  "sourceRoot": "packages/nucleotide/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/nucleotide/tsconfig.build.json && add-import-extensions packages/nucleotide/dist --external-deep --ignore '@ncbijs/*'"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run --config packages/nucleotide/vitest.config.ts" }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": { "lintFilePatterns": ["{projectRoot}/**/*.ts"] }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit -p packages/nucleotide/tsconfig.json" }
    }
  }
}
