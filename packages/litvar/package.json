{
  "name": "@ncbijs/litvar",
  "version": "1.0.0",
  "description": "LitVar2 API client — find literature linked to genetic variants by rsID",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/litvar"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/litvar#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbijs",
    "ncbi",
    "litvar",
    "variant",
    "snp",
    "rsid",
    "literature",
    "pubmed",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@ncbijs/rate-limiter": "workspace:*"
  },
  "scripts": {
    "prepublishOnly": "echo 'Use CI to publish' && exit 1"
  }
}
