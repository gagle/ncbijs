{
  "name": "@ncbijs/books",
  "sourceRoot": "packages/books/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/books/tsconfig.build.json && add-import-extensions packages/books/dist --external-deep --ignore '@ncbijs/*'"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run --config packages/books/vitest.config.ts" }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": { "lintFilePatterns": ["{projectRoot}/**/*.ts"] }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit -p packages/books/tsconfig.json" }
    }
  }
}
