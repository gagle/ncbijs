{
  "name": "@ncbijs/pubtator",
  "version": "1.0.0",
  "description": "Text mining client for PubTator/BioC APIs with entity annotations and relation discovery",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/pubtator"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/pubtator#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbijs",
    "ncbi",
    "pubtator",
    "bioc",
    "text-mining",
    "ner",
    "nlp",
    "entity",
    "gene",
    "disease",
    "chemical",
    "annotation",
    "bioinformatics",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@ncbijs/rate-limiter": "workspace:*",
    "@ncbijs/xml": "workspace:*"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prepublishOnly": "echo 'Use CI to publish' && exit 1"
  }
}
