{
  "name": "@ncbijs/pubtator",
  "version": "0.0.1",
  "description": "Text mining client for PubTator/BioC APIs with entity annotations and relation discovery",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/pubtator"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/pubtator#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbi",
    "pubtator",
    "bioc",
    "text-mining",
    "ner",
    "entity",
    "annotation",
    "bioinformatics",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "prepublishOnly": "echo 'Use CI to publish' && exit 1",
  "sideEffects": false,
  "files": [
    "dist",
    "package.json",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
