{
  "name": "@ncbijs/eutils",
  "version": "0.1.0",
  "description": "Spec-compliant HTTP client for all 9 NCBI E-utilities",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/eutils"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/eutils#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbijs",
    "ncbi",
    "eutils",
    "e-utilities",
    "entrez",
    "bioinformatics",
    "typescript"
  ],
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@ncbijs/rate-limiter": "workspace:*",
    "@ncbijs/xml": "workspace:*",
    "openapi-fetch": "^0.17.0"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prepublishOnly": "echo 'Use CI to publish' && exit 1"
  }
}
