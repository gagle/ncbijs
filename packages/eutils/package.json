{
  "name": "@ncbijs/eutils",
  "version": "0.0.1",
  "description": "Spec-compliant HTTP client for all 9 NCBI E-utilities",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/eutils"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/eutils#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbi",
    "eutils",
    "e-utilities",
    "entrez",
    "pubmed",
    "bioinformatics",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "prepublishOnly": "echo 'Use CI to publish' && exit 1",
  "dependencies": {
    "@ncbijs/rate-limiter": "workspace:*",
    "openapi-fetch": "^0.17.0"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
