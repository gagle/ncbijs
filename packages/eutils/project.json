{
  "name": "@ncbijs/eutils",
  "sourceRoot": "packages/eutils/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/eutils/tsconfig.build.json && tsc-esm-imports packages/eutils/dist --external-deep --ignore '@ncbijs/*'"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config packages/eutils/vitest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["{projectRoot}/**/*.ts"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p packages/eutils/tsconfig.json"
      }
    }
  }
}
