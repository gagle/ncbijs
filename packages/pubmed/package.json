{
  "name": "@ncbijs/pubmed",
  "version": "0.0.1",
  "description": "High-level PubMed article search and retrieval client",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/pubmed"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/pubmed#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbijs",
    "ncbi",
    "pubmed",
    "biomedical",
    "literature",
    "search",
    "article",
    "bioinformatics",
    "rag",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "prepublishOnly": "echo 'Use CI to publish' && exit 1",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "dependencies": {
    "@ncbijs/eutils": "workspace:*",
    "@ncbijs/pubmed-xml": "workspace:*"
  }
}
