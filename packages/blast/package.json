{
  "name": "@ncbijs/blast",
  "version": "0.0.0",
  "description": "NCBI BLAST sequence alignment client with async submit/poll/retrieve workflow",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/blast"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/blast#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbijs",
    "ncbi",
    "blast",
    "sequence",
    "alignment",
    "nucleotide",
    "protein",
    "bioinformatics",
    "typescript"
  ],
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@ncbijs/rate-limiter": "workspace:*"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prepublishOnly": "echo 'Use CI to publish' && exit 1"
  }
}
