{
  "name": "@ncbijs/pubchem",
  "sourceRoot": "packages/pubchem/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/pubchem/tsconfig.build.json && node scripts/add-import-extensions.mjs packages/pubchem/dist"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run --config packages/pubchem/vitest.config.ts" }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": { "lintFilePatterns": ["{projectRoot}/**/*.ts"] }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc --noEmit -p packages/pubchem/tsconfig.json" }
    }
  }
}
