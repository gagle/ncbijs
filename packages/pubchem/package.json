{
  "name": "@ncbijs/pubchem",
  "version": "0.0.1",
  "description": "Typed client for the PubChem PUG REST API (compounds, substances, assays)",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/pubchem"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/pubchem#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbi",
    "pubchem",
    "compound",
    "chemical",
    "chemistry",
    "bioinformatics",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "prepublishOnly": "echo 'Use CI to publish' && exit 1",
  "dependencies": {
    "@ncbijs/rate-limiter": "workspace:*"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "package.json",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
