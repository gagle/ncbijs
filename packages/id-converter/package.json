{
  "name": "@ncbijs/id-converter",
  "version": "0.0.1",
  "description": "Batch article ID conversion between PMID, PMCID, DOI, and Manuscript ID",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/id-converter"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/id-converter#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbi",
    "pmid",
    "pmcid",
    "doi",
    "id-converter",
    "pmc",
    "bioinformatics",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "prepublishOnly": "echo 'Use CI to publish' && exit 1",
  "sideEffects": false,
  "files": [
    "dist",
    "package.json",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
