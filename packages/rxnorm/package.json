{
  "name": "@ncbijs/rxnorm",
  "version": "1.0.0",
  "description": "Typed client for the RxNorm REST API — drug name normalization, concept lookup, drug classes, and NDC codes",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/rxnorm"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/rxnorm#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbijs",
    "rxnorm",
    "drug",
    "medication",
    "pharmacy",
    "ndc",
    "rxcui",
    "rxclass",
    "nlm",
    "typescript"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@ncbijs/rate-limiter": "workspace:*"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prepublishOnly": "echo 'Use CI to publish' && exit 1"
  }
}
