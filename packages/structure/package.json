{
  "name": "@ncbijs/structure",
  "version": "0.1.1",
  "description": "Typed client for NCBI Structure (MMDB/PDB) macromolecular 3D structures",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git",
    "directory": "packages/structure"
  },
  "homepage": "https://github.com/gagle/ncbijs/tree/main/packages/structure#readme",
  "bugs": {
    "url": "https://github.com/gagle/ncbijs/issues"
  },
  "keywords": [
    "ncbijs",
    "ncbi",
    "structure",
    "mmdb",
    "pdb",
    "protein",
    "3d",
    "crystallography",
    "bioinformatics",
    "typescript"
  ],
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@ncbijs/eutils": "workspace:*",
    "@ncbijs/rate-limiter": "workspace:*"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prepublishOnly": "echo 'Use CI to publish' && exit 1"
  }
}
