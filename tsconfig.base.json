{
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declarationMap": true,
    "inlineSources": true,
    "declaration": false,
    "target": "ES2022",
    "module": "esnext",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noPropertyAccessFromIndexSignature": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@ncbijs/eutils": ["./packages/eutils/src/index.ts"],
      "@ncbijs/eutils/config": ["./packages/eutils/src/config.ts"],
      "@ncbijs/pubmed-xml": ["./packages/pubmed-xml/src/index.ts"],
      "@ncbijs/pubmed": ["./packages/pubmed/src/index.ts"],
      "@ncbijs/jats": ["./packages/jats/src/index.ts"],
      "@ncbijs/pmc": ["./packages/pmc/src/index.ts"],
      "@ncbijs/id-converter": ["./packages/id-converter/src/index.ts"],
      "@ncbijs/pubtator": ["./packages/pubtator/src/index.ts"],
      "@ncbijs/mesh": ["./packages/mesh/src/index.ts"],
      "@ncbijs/cite": ["./packages/cite/src/index.ts"],
      "@ncbijs/http-mcp": ["./packages/http-mcp/src/index.ts"],
      "@ncbijs/rate-limiter": ["./packages/rate-limiter/src/index.ts"],
      "@ncbijs/xml": ["./packages/xml/src/index.ts"],
      "@ncbijs/fasta": ["./packages/fasta/src/index.ts"],
      "@ncbijs/datasets": ["./packages/datasets/src/index.ts"],
      "@ncbijs/blast": ["./packages/blast/src/index.ts"],
      "@ncbijs/snp": ["./packages/snp/src/index.ts"],
      "@ncbijs/clinvar": ["./packages/clinvar/src/index.ts"],
      "@ncbijs/pubchem": ["./packages/pubchem/src/index.ts"],
      "@ncbijs/genbank": ["./packages/genbank/src/index.ts"],
      "@ncbijs/protein": ["./packages/protein/src/index.ts"],
      "@ncbijs/nucleotide": ["./packages/nucleotide/src/index.ts"],
      "@ncbijs/omim": ["./packages/omim/src/index.ts"],
      "@ncbijs/medgen": ["./packages/medgen/src/index.ts"],
      "@ncbijs/gtr": ["./packages/gtr/src/index.ts"],
      "@ncbijs/geo": ["./packages/geo/src/index.ts"],
      "@ncbijs/dbvar": ["./packages/dbvar/src/index.ts"],
      "@ncbijs/sra": ["./packages/sra/src/index.ts"],
      "@ncbijs/structure": ["./packages/structure/src/index.ts"],
      "@ncbijs/cdd": ["./packages/cdd/src/index.ts"],
      "@ncbijs/books": ["./packages/books/src/index.ts"],
      "@ncbijs/nlm-catalog": ["./packages/nlm-catalog/src/index.ts"],
      "@ncbijs/rxnorm": ["./packages/rxnorm/src/index.ts"],
      "@ncbijs/litvar": ["./packages/litvar/src/index.ts"],
      "@ncbijs/clinical-trials": ["./packages/clinical-trials/src/index.ts"],
      "@ncbijs/icite": ["./packages/icite/src/index.ts"],
      "@ncbijs/bioc": ["./packages/bioc/src/index.ts"],
      "@ncbijs/clinical-tables": ["./packages/clinical-tables/src/index.ts"],
