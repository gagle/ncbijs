{
  "name": "ncbijs-workspace",
  "version": "1.0.0",
  "description": "TypeScript clients for NCBI APIs — PubMed, PMC, BLAST, SNP, ClinVar, PubChem, Datasets, and more",
  "author": "Gabriel Llamas",
  "license": "MIT",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gagle/ncbijs.git"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@nx/devkit": "^22.7.0",
    "@nx/eslint": "^22.7.0",
    "@nx/eslint-plugin": "^22.7.0",
    "@types/node": "^20.19.9",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nx": "^22.7.0",
    "prettier": "^3.8.3",
    "tsc-esm-imports": "0.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "lmdb",
      "nx"
    ]
  }
}
