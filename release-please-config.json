{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "pull-request-header": "",
  "pull-request-footer": "",
  "separate-pull-requests": false,
  "group-pull-request-title-pattern": "chore: release ${version}",
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "ncbijs",
      "components": [
        "@ncbijs/eutils",
        "@ncbijs/pubmed-xml",
        "@ncbijs/pubmed",
        "@ncbijs/jats",
        "@ncbijs/pmc",
        "@ncbijs/id-converter",
        "@ncbijs/pubtator",
        "@ncbijs/mesh",
        "@ncbijs/cite",
        "@ncbijs/rate-limiter"
      ]
    },
    {
      "type": "node-workspace"
    }
  ],
  "packages": {
    "packages/eutils": {
      "release-type": "node",
      "component": "@ncbijs/eutils",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true
    },
    "packages/pubmed-xml": {
      "release-type": "node",
      "component": "@ncbijs/pubmed-xml",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true
    },
    "packages/pubmed": {
      "release-type": "node",
      "component": "@ncbijs/pubmed",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true
    },
    "packages/jats": {
      "release-type": "node",
      "component": "@ncbijs/jats",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true
    },
    "packages/pmc": {
      "release-type": "node",
      "component": "@ncbijs/pmc",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true
    },
    "packages/id-converter": {
      "release-type": "node",
      "component": "@ncbijs/id-converter",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true
    },
    "packages/pubtator": {
      "release-type": "node",
      "component": "@ncbijs/pubtator",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true
    },
    "packages/mesh": {
      "release-type": "node",
      "component": "@ncbijs/mesh",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true
    },
    "packages/cite": {
      "release-type": "node",
      "component": "@ncbijs/cite",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true
    },
    "packages/rate-limiter": {
      "release-type": "node",
      "component": "@ncbijs/rate-limiter",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true
    }
  }
}
