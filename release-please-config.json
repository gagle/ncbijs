{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "pull-request-header": "",
  "pull-request-footer": "",
  "separate-pull-requests": false,
  "group-pull-request-title-pattern": "chore: release ${version}",
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "ncbijs",
      "components": [
        "@ncbijs/eutils",
        "@ncbijs/pubmed-xml",
        "@ncbijs/pubmed",
        "@ncbijs/jats",
        "@ncbijs/pmc",
        "@ncbijs/id-converter",
        "@ncbijs/pubtator",
        "@ncbijs/mesh",
        "@ncbijs/cite",
        "@ncbijs/mcp",
        "@ncbijs/rate-limiter",
        "@ncbijs/xml",
        "@ncbijs/fasta",
        "@ncbijs/datasets",
        "@ncbijs/blast",
        "@ncbijs/snp",
        "@ncbijs/clinvar",
        "@ncbijs/pubchem",
        "@ncbijs/genbank",
        "@ncbijs/protein",
        "@ncbijs/nucleotide",
        "@ncbijs/omim",
        "@ncbijs/medgen",
        "@ncbijs/gtr",
        "@ncbijs/geo",
        "@ncbijs/dbvar",
        "@ncbijs/sra"
      ]
    },
    {
      "type": "node-workspace"
    }
  ],
  "packages": {
    "packages/eutils": {
      "release-type": "node",
      "component": "@ncbijs/eutils",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": true
